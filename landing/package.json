{
	"name": "dartlab-landing",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "node scripts/syncBrand.js && node scripts/syncBlogAssets.js prepare",
		"build": "vite build",
		"postbuild": "node scripts/syncBlogAssets.js finalize && node scripts/postbuild.js",
		"sync-brand": "node scripts/syncBrand.js",
		"preview": "vite preview",
