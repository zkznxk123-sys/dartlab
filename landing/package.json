{
	"name": "dartlab-landing",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host 127.0.0.1 --port 5173 --strictPort",
		"dev:any": "vite dev --host 127.0.0.1",
		"prebuild": "node scripts/checkDevIsolation.js && node scripts/syncBrand.js && node scripts/syncBlogAssets.js prepare",
		"build": "node --max-old-space-size=8192 scripts/viteHeap.mjs build",
		"postbuild": "node scripts/syncBlogAssets.js finalize && node scripts/postbuild.js",
		"sync-brand": "node scripts/syncBrand.js",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/d3-force": "^3.0.10",
		"@types/d3-scale": "^4.0.9",
		"@types/dompurify": "^3.2.0",
		"@types/node": "^25.9.3",
		"dompurify": "^3.4.10",
		"mdsvex": "^0.12.7",
		"shiki": "^4.2.0",
		"svelte": "5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.2.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@dartlab/ui-design": "*",
		"@codemirror/autocomplete": "^6.20.3",
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-sql": "^6.10.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.43.1",
		"@cosmograph/cosmos": "^1.6.1",
		"@huggingface/transformers": "^4.2.0",
		"@mlc-ai/web-llm": "^0.2.84",
		"@types/d3-hierarchy": "^3.1.7",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"d3-force": "^3.0.0",
		"d3-hierarchy": "^3.1.2",
		"d3-scale": "^4.0.2",
		"hyparquet": "^1.26.0",
		"hyparquet-compressors": "^1.1.1",
		"klinecharts": "^9.8.12",
		"layerchart": "^1.0.13",
		"lucide-svelte": "^1.0.1",
		"tailwind-merge": "^3.6.0",
		"unist-util-visit": "^5.1.0"
	}
}
