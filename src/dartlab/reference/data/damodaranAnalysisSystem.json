  "dataContract": {
    "financialStatements": {
      "owner": "Company.show",
      "topics": [
        "IS",
        "BS",
        "CF"
      ],
      "minimumPanelYears": 5,
      "requiredAccounts": [
        "sales/revenue",
        "operating_profit/operating_income",
        "profit_before_tax",
        "income_taxes",
        "operating_cashflow",
        "purchase_of_property_plant_and_equipment",
        "depreciation",
        "cash_and_cash_equivalents",
        "debt",
        "equity",
        "nonCashWorkingCapital"
      ]
    },
    "marketData": {
      "owner": "dartlab.gather plus local market snapshots",
      "requiredFields": [
        "price",
        "priceDate",
        "marketCap",
        "shares"
      ],
      "krPreferredPath": "data/krx/prices/raw-2026.parquet",
      "usPreferredPath": "dartlab.gather(\"price\", market=\"US\") plus data/edgar/finance/{cik}.parquet shares"
    },
    "referenceData": {
      "owner": "dartlab.reference.data JSON snapshots",
      "files": [
        "damodaranDefaults.json",
        "damodaranIndustryDefaults.json",
        "damodaranAnalysisSystem.json"
      ],
      "requiredFields": [
        "country ERP",
        "risk-free rate",
        "marginal tax rate",
        "industry beta",
        "industry WACC",
        "sales-to-capital",
        "operating margin",
        "ROC proxy"
      ]
    },
    "textEvidence": {
      "owner": "Company.topics / Company.show text topics",
      "requiredAliases": [
        "businessOverview",
        "productService",
        "segments",
        "riskFactors",
        "managementDiscussion"
      ],
      "status": "deferredWithBlocker"
    },
    "peerValuation": {
      "owner": "scan/reference primitive",
      "requiredFields": [
        "peerUniverse",
        "EV/Sales",
        "EV/EBIT",
        "PE",
        "PB",
        "growth",
        "margin",
        "risk"
      ],
      "status": "deferredWithBlocker"
    }
  },
