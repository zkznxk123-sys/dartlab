{
  "name": "dartlab",
  "displayName": "DartLab",
  "description": "DART 전자공시 & EDGAR AI 기업분석 — 종목코드 하나로 재무분석, 밸류에이션, 공시 검색",
  "version": "0.2.3",
  "publisher": "eddmpython",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "keywords": [
    "dart",
    "financial",
    "korea",
    "stock",
    "analysis",
    "edgar"
  ],
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/eddmpython/dartlab"
  },
  "homepage": "https://eddmpython.github.io/dartlab/",
  "bugs": {
    "url": "https://github.com/eddmpython/dartlab/issues"
  },
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dartlab",
          "title": "DartLab",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "dartlab": [
        {
          "type": "webview",
          "id": "dartlab.sidebar",
          "name": "DartLab"
        }
      ]
    },
    "commands": [
      {
        "command": "dartlab.open",
        "title": "DartLab: New Chat",
        "icon": "$(add)"
      },
      {
        "command": "dartlab.settings",
        "title": "DartLab: AI Settings"
      },
      {
        "command": "dartlab.restart",
        "title": "DartLab: Restart Server"
      },
      {
        "command": "dartlab.showLogs",
        "title": "DartLab: Show Logs"
      },
      {
        "command": "dartlab.newConversation",
        "title": "DartLab: New Conversation"
      },
      {
        "command": "dartlab.focus",
        "title": "DartLab: Focus Input"
      },
      {
        "command": "dartlab.diagnostics",
        "title": "DartLab: 진단 정보"
      }
    ],
    "keybindings": [
      {
        "command": "dartlab.open",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "dartlab.newConversation",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "dartlab.panelFocused"
      }
    ],
    "configuration": {
      "title": "DartLab",
      "properties": {
        "dartlab.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Python executable path (auto-detect if empty)"
        },
        "dartlab.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Auto-start server on activation"
        }
      }
    }
  },
  "scripts": {
    "dev": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs --production",
    "test": "npx vitest run",
    "verify": "node esbuild.mjs --production && cd webview && npx vite build && cd .. && npx vitest run && npx tsc -p tsconfig.json && npx vscode-test",
    "lint": "eslint src/",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "esbuild": "^0.24.0",
    "mocha": "^11.7.5",
    "playwright": "^1.58.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2",
    "wdio-vscode-service": "^6.1.4",
    "webdriverio": "^8.46.0"
  }
}
