{
	"compilerOptions": {
		"baseUrl": ".",
		"paths": {
			"$lib": ["./src/lib"],
			"$lib/*": ["./src/lib/*"],
			"$shared": ["../shared"],
			"$shared/*": ["../shared/*"]
		},
		"module": "esnext",
		"target": "esnext",
		"moduleResolution": "bundler",
		"allowJs": true,
		"checkJs": false
	},
	"include": ["src/**/*.js", "src/**/*.svelte"]
}
