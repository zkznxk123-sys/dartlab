{
	"name": "dartlab-ui",
	"private": true,
	"version": "0.2.0",
	"type": "module",
	"description": "DartLab desktop dashboard — React + Vite + shadcn/ui. Bundled into dartlab Python wheel.",
	"scripts": {
		"dev": "vite dev --port 5400",
		"build": "tsc -b && vite build",
		"preview": "vite preview --port 5400",
		"typecheck": "tsc -b --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"gen:api": "node scripts/genApi.mjs"
	},
	"dependencies": {
		"@msgpack/msgpack": "^3.1.3",
		"@tanstack/react-query": "^5.62.0",
		"@tanstack/react-router": "^1.95.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lightweight-charts": "^5.2.0",
		"lucide-react": "^0.460.0",
		"mermaid": "^11.15.0",
		"radix-ui": "^1.4.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-markdown": "^10.1.0",
		"recharts": "^3.8.1",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.0.0",
		"tailwindcss-animate": "^1.0.7",
		"tw-animate-css": "^1.4.0",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@tailwindcss/vite": "^4.0.0",
		"@tanstack/react-router-devtools": "^1.95.0",
		"@tanstack/router-plugin": "^1.95.0",
		"@types/node": "^22.10.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.4",
		"openapi-typescript": "^7.5.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.7.2",
		"vite": "^6.0.0",
		"vitest": "^3.0.0"
	}
}
