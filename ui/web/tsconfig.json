{
	"compilerOptions": {
		"allowJs": true,
		"checkJs": false,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": false,
		"moduleResolution": "bundler",
		"module": "esnext",
		"target": "esnext",
		"baseUrl": ".",
		"paths": { "$lib/*": ["./src/lib/*"], "$lib": ["./src/lib"] }
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "build", "dist"]
}
